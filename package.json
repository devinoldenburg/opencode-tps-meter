{
  "name": "@devinoldenburg/opencode-tps-meter",
  "version": "0.1.8",
  "description": "A precise tokens-per-second (TPS) meter for the OpenCode TUI sidebar — live throughput, time-to-first-token, and per-session averages, measured from the OpenCode event stream.",
  "type": "module",
  "main": "plugins/tps/root.js",
  "types": "plugins/tps/index.d.ts",
  "exports": {
    ".": "./plugins/tps/root.js",
    "./tui": "./plugins/tps-meter.tsx",
    "./core": "./plugins/tps/index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "npm@10",
  "bin": {
    "opencode-tps-meter": "scripts/install.mjs",
    "opencode-tps-meter-install": "scripts/install.mjs"
  },
  "files": [
    "plugins/",
    "scripts/install.mjs",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "VERSIONING.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "demo": "node tools/demo.mjs",
    "peers": "node tools/install-peers.mjs",
    "verify:plugin": "node tools/install-peers.mjs && bun tools/verify-plugin.mjs",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "validate": "npm test && npm run typecheck && npm run pack:check"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-tui-plugin",
    "tui",
    "sidebar",
    "tps",
    "tokens-per-second",
    "throughput",
    "tokens",
    "metrics",
    "stats",
    "telemetry",
    "ttft",
    "llm",
    "ai",
    "coding-agent",
    "developer-tools",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devinoldenburg/opencode-tps-meter.git"
  },
  "bugs": {
    "url": "https://github.com/devinoldenburg/opencode-tps-meter/issues"
  },
  "homepage": "https://github.com/devinoldenburg/opencode-tps-meter#readme",
  "author": "Devin Oldenburg (https://github.com/devinoldenburg)",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.6",
    "@opentui/solid": "0.4.1",
    "@types/node": "^24.0.3",
    "solid-js": "1.9.12",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0",
    "@opentui/solid": ">=0.4.1 <1",
    "solid-js": ">=1.9.12 <2"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  }
}
